{
	"name": "print-friendly",
	"description": "Convert a markdown file to a print-ready, styled HTML file",
	"version": "0.4.1",
	"type": "module",
	"scripts": {
		"format": "prettier --write .",
		"version": "node cli/version && git add .",
		"postversion": "git push && git push --tags"
	},
