		"url": "git+https://github.com/hyunbinseo/print-friendly.git"
	},
	"bugs": {
		"url": "https://github.com/hyunbinseo/print-friendly/issues"
	},
	"homepage": "https://github.com/hyunbinseo/print-friendly#readme",
